import pgzrun
import random
import math

# Константы игры
TITLE = 'Тык-тык'
WIDTH = 800
HEIGHT = 600
BACKGROUND_COLOR = (20, 30, 40)
TEXT_COLOR = (220, 220, 220)
SECONDARY_TEXT_COLOR = (200, 200, 200)
HINT_TEXT_COLOR = (180, 180, 200)
HELP_TEXT_COLOR = (160, 160, 180)
MIN_SPEED = 1.0
MAX_SPEED = 3.0
MIN_CIRCLES = 5
MAX_CIRCLES = 10
MAX_TOTAL_CIRCLES = 50  # Максимум кружков на экране
MAX_SCORE = 25  # Победа после 25 лопнутых кружков


class Circle:
    def __init__(self):
        # Случайные параметры кружочка
        self.radius = random.randint(15, 35)
        self.color = (random.randint(100, 255), random.randint(100, 255), random.randint(100, 255))
        self.x = random.randint(self.radius, WIDTH - self.radius)
        self.y = random.randint(self.radius, HEIGHT - self.radius)
        # Случайная скорость и направление
        speed = random.uniform(MIN_SPEED, MAX_SPEED)
        angle = random.uniform(0, 2 * math.pi)
        self.dx = math.cos(angle) * speed
        self.dy = math.sin(angle) * speed
        # Анимация лопанья
        self.is_popping = False
        self.pop_progress = 0.0
        self.pop_speed = 0.2

    def move(self, multiplier):
        # Движение и отскок от стен
        if self.is_popping:
            return
        self.x += self.dx * multiplier
        self.y += self.dy * multiplier
        if self.x - self.radius < 0:
            self.x = self.radius
            self.dx = -self.dx
        if self.x + self.radius > WIDTH:
            self.x = WIDTH - self.radius
            self.dx = -self.dx
        if self.y - self.radius < 0:
            self.y = self.radius
            self.dy = -self.dy
        if self.y + self.radius > HEIGHT:
            self.y = HEIGHT - self.radius
            self.dy = -self.dy

    def update(self):
        # Обновление анимации лопанья
        if not self.is_popping:
            return False
        self.pop_progress += self.pop_speed
        return self.pop_progress >= 1

    def draw(self):
        # Отрисовка кружочка
        if not self.is_popping:
            screen.draw.filled_circle((self.x, self.y), self.radius, self.color)
            screen.draw.circle((self.x, self.y), self.radius, (255, 255, 255))
            return
        # Лопающийся кружок уменьшается
        r = int(self.radius * (1 - self.pop_progress))
        if r < 1:
            r = 1
        screen.draw.filled_circle((self.x, self.y), r, self.color)

    def is_clicked(self, pos):
        # Проверка клика по кружку
        d = math.sqrt((self.x - pos[0]) ** 2 + (self.y - pos[1]) ** 2)
        return d <= self.radius


class Game:
    def __init__(self):
        self.setup_game()

    def setup_game(self):
        # Сброс игры
        self.circles = []
        self.score = 0
        self.speed_multiplier = 1.0
        self.game_over = False
        # Создание начальных кружков
        count = random.randint(MIN_CIRCLES, MAX_CIRCLES)
        for _ in range(count):
            self.circles.append(self.spawn_circle())

    def spawn_circle(self):
        # Создание нового кружка
        return Circle()

    def handle_click(self, pos):
        # Обработка клика
        if self.game_over:
            return
        for circle in self.circles:
            if circle.is_clicked(pos):
                circle.is_popping = True
                self.score += 1
                self.speed_multiplier = 1 + self.score * 0.1
                # Проверка победы
                if self.score >= MAX_SCORE:
                    self.game_over = True
                break

    def update(self):
        # Обновление игры
        if self.game_over:
            return
        new_circles = []
        popped = 0
        # Обновление всех кружков
        for c in self.circles:
            if c.update():
                popped += 1
            else:
                new_circles.append(c)
        self.circles = new_circles
        # Добавление новых кружков вместо лопнувших
        circles_to_add = min(popped, MAX_TOTAL_CIRCLES - len(self.circles))
        for _ in range(circles_to_add):
            self.circles.append(self.spawn_circle())
        # Движение всех кружков
        for c in self.circles:
            c.move(self.speed_multiplier)

    def draw(self):
        # Отрисовка игры
        screen.fill(BACKGROUND_COLOR)
        # Рисование кружков
        for c in self.circles:
            c.draw()
        # Экран победы
        if self.game_over:
            screen.draw.text('ПОБЕДА!', center=(WIDTH // 2, HEIGHT // 2 - 40), fontsize=72, color=(255, 215, 0))
            screen.draw.text(f'Вы лопнули {self.score} кружков! БЕБРАААА!', center=(WIDTH // 2, HEIGHT // 2 + 30),fontsize=36, color=TEXT_COLOR)
            screen.draw.text('Нажми R для новой игры', center=(WIDTH // 2, HEIGHT // 2 + 80), fontsize=28,color=HINT_TEXT_COLOR)
        # Интерфейс
        screen.draw.text(f'Счет: {self.score}/{MAX_SCORE}', topleft=(20, 20), fontsize=30, color=TEXT_COLOR)
        screen.draw.text(f'Скорость: x{self.speed_multiplier:.1f}', topright=(WIDTH - 20, 20), fontsize=30,color=SECONDARY_TEXT_COLOR)
        screen.draw.text('Нажимай левой кнопкой мыши на шарики, чтобы лопать их', center=(WIDTH // 2, HEIGHT - 40),fontsize=24, color=HINT_TEXT_COLOR)
        screen.draw.text('R - новая игра | ESC - выход', center=(WIDTH // 2, HEIGHT - 15), fontsize=20,color=HELP_TEXT_COLOR)


game = Game()


def update():
    game.update()


def draw():
    game.draw()


